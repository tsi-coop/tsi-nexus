# TSI Nexus - Environment Configuration
# Copy this file to .env and edit the values before running docker compose.

# ── Port mapping ─────────────────────────────────────────────────────────────
# Format: HOST_PORT:CONTAINER_PORT
APP_PORT_MAP=8084:8080
DB_PORT_MAP=5436:5432

# ── LLM endpoint ─────────────────────────────────────────────────────────────
# Point to any vLLM instance or OpenAI-compatible API.
VLLM_URL=http://192.168.1.77:8001
VLLM_MODEL=gemma-4-26B-A4B-it

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=tsi_nexus
POSTGRES_USER=tsi_admin
POSTGRES_PASSWD=secure_dev_password        # Change for production

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing secret - use a long random string in production.
TSI_NEXUS_JWT_SECRET=tsi-nexus-default-dev-secret-key-256-bits-minimum!!

# ── Export path (inside container) ────────────────────────────────────────────
TSI_EXPORT_PATH=/var/lib/tsi/exports/

# ── Environment label (informational, shown in server logs) ───────────────────
TSI_PRIVACY_VAULT_ENV=development
